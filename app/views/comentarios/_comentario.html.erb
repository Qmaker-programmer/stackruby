<div style="margin-left: 20px; border-left: 2px solid var(--border-color); padding-left: 15px; margin-top: 12px; margin-bottom: 12px;">
  <p style="margin: 0; font-size: 0.85em; color: var(--text-secundario); display: flex; align-items: center; gap: 6px;">
    <% if comentario.usuario.foto_base64.present? %>
      <img src="<%= comentario.usuario.foto_base64 %>" style="width: 16px; height: 16px; border-radius: 50%; object-fit: cover;">
    <% else %>
      <span>👤</span>
    <% end %>
    <strong style="color: #fff;"><%= comentario.usuario.nombre %></strong> | Votos: <span style="color: var(--accent); font-weight: bold;"><%= comentario.votos %></span>
  </p>
  
  <p style="margin: 6px 0; color: var(--text-principal); font-size: 0.95em; white-space: pre-line;"><%= comentario.cuerpo %></p>

  <div style="display: flex; gap: 12px; font-size: 0.8em; align-items: center;">
    <%= link_to "▲", votar_arriba_preguntum_comentario_path(comentario.preguntum, comentario), method: :patch, style: "color: var(--accent); font-weight: bold;" %>
    <%= link_to "▼", votar_abajo_preguntum_comentario_path(comentario.preguntum, comentario), method: :patch, style: "color: #da3633; font-weight: bold;" %>
    
    <details style="display: inline;">
      <summary style="cursor: pointer; color: var(--text-secundario); list-style: none;">Responder</summary>
      <%= form_with url: preguntum_comentarios_path(comentario.preguntum), local: true, style: "margin-top: 8px; min-width: 250px;" do |f| %>
        <%= hidden_field_tag :comentario_padre_id, comentario.id %>
        <%= f.text_area :cuerpo, rows: 2, placeholder: "Escribe tu respuesta pública...", required: true, style: "margin-bottom: 8px;" %><br>
        <%= f.submit "Responder", style: "padding: 6px 12px; font-size: 0.85em;" %>
      <% end %>
    </details>
  </div>

  <% if comentario.hijos.any? %>
    <%= render partial: 'comentarios/comentario', collection: comentario.hijos.order(votos: :desc, created_at: :asc) %>
  <% end %>
</div>