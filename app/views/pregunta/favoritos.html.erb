<h1>⭐ Mis Favoritos</h1>

<p style="color: var(--text-secundario); margin-bottom: 30px;">
  Preguntas a las que les has dado estrella
</p>

<% if @preguntas_favoritas.empty? %>
  <div class="card">
    <p style="text-align: center; color: var(--text-secundario); padding: 40px 20px;">
      No has dado estrella a ninguna pregunta aún.<br>
      <%= link_to "Ver todas las preguntas →", root_path, style: "color: var(--accent); font-weight: bold;" %>
    </p>
  </div>
<% else %>
  <% @preguntas_favoritas.each do |preguntum| %>
    <div class="card">
      <h3 style="margin-bottom: 8px;">
        <%= link_to preguntum.titulo, preguntum %>
        <span style="color: #ffd700; font-size: 0.9em; margin-left: 8px;">★</span>
      </h3>

      <p style="font-size: 0.85em; color: var(--text-secundario); margin-bottom: 15px; display: flex; align-items: center; gap: 8px;">
        <% if preguntum.usuario&.foto_base64.present? %>
          <img src="<%= preguntum.usuario.foto_base64 %>" style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;">
        <% end %>
        Publicado por:
        <% if preguntum.usuario.present? %>
          <%= link_to preguntum.usuario.nombre, usuario_path(preguntum.usuario), style: "font-weight: bold; color: var(--accent);" %>
        <% else %>
          <em>Anónimo</em>
        <% end %>
        • <%= preguntum.created_at.strftime("%d/%m/%Y %H:%M") %>
      </p>

      <div style="color: var(--text-principal); font-size: 1em; margin-bottom: 15px;">
        <%= (preguntum.cuerpo_html || preguntum.cuerpo).truncate_words(30, separator: ' ', omission: '...').html_safe %>
      </div>

      <div style="display: flex; align-items: center; gap: 12px; background: var(--bg-principal); padding: 8px 12px; border-radius: 6px; width: fit-content; border: 1px solid var(--border-color);">
        <strong style="color: #ffd700; font-size: 1.1em;">★ <%= preguntum.total_estrellas %></strong>
        <span style="color: var(--text-secundario); font-size: 0.85em;">·</span>
        <span style="color: var(--text-secundario); font-size: 0.85em;"><%= preguntum.vistas %> vistas</span>
      </div>
    </div>
  <% end %>
<% end %>
