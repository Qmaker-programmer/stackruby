<%= link_to "Volver al Inicio", root_path, style: "color: var(--text-secundario);" %>

<div class="card" style="margin-top: 20px;">
  <h1 style="margin-bottom: 10px;"><%= @preguntum.titulo %></h1>

  <p style="color: var(--text-secundario); font-size: 0.9em; display: flex; align-items: center; gap: 8px; margin-bottom: 15px;">
    <% if @preguntum.usuario&.foto_base64.present? %>
      <img src="<%= @preguntum.usuario.foto_base64 %>" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;">
    <% end %>
    Publicado por: <strong><%= link_to @preguntum.usuario&.nombre || "Anonimo", usuario_path(@preguntum.usuario) %></strong> |
    <strong style="color: #ffd700; font-size: 1.1em;">★ <%= @preguntum.total_estrellas %> estrellas</strong> |
    <span style="color: var(--text-secundario);"><%= @preguntum.vistas %> vistas</span>
  </p>

  <% if usuario_actual %>
    <div style="margin-bottom: 20px;">
      <% if @preguntum.usuario_id != usuario_actual.id %>
        <% if @preguntum.tiene_estrella_de?(usuario_actual) %>
          <%= button_to "★ Quitar Estrella", toggle_estrella_preguntum_path(@preguntum), method: :post, style: "background: none; border: 1px solid #ffd700; padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: normal; font-size: 0.9em; color: #ffd700;" %>
        <% else %>
          <%= button_to "☆ Dar Estrella", toggle_estrella_preguntum_path(@preguntum), method: :post, style: "background: none; border: 1px solid var(--border-color); padding: 8px 12px; border-radius: 4px; cursor: pointer; font-weight: normal; font-size: 0.9em; color: var(--text-secundario);" %>
        <% end %>
      <% end %>

      <% if @preguntum.usuario_id == usuario_actual.id && @preguntum.total_estrellas > 0 %>
        <div style="margin-top: 15px; padding: 10px; background: rgba(255, 215, 0, 0.05); border: 1px solid var(--border-color); border-radius: 4px;">
          <p style="margin: 0; color: var(--text-secundario); font-size: 0.85em;">
            <%= @preguntum.total_estrellas %> persona(s) le dieron estrella.
            <%= link_to "Ver quiénes", quien_dio_estrella_preguntum_path(@preguntum), style: "color: var(--accent);" %>
          </p>
        </div>
      <% end %>
    </div>
  <% end %>

  <hr style="border: 0; border-top: 1px solid var(--border-color); margin-bottom: 20px;">

  <% if params[:ver_markdown] == 'true' %>
    <div style="padding: 15px; background: var(--bg-principal); border: 1px solid var(--border-color); border-radius: 6px; margin-bottom: 15px;">
      <h3 style="margin-top: 0; color: var(--accent); font-size: 1em;">Código Markdown Original:</h3>
      <pre style="background: #000; padding: 12px; border-radius: 4px; overflow-x: auto; color: #0f0; font-family: 'Courier New', monospace; font-size: 0.9em; white-space: pre-wrap;"><%= @preguntum.cuerpo_markdown %></pre>
      <%= link_to "← Ver HTML renderizado", preguntum_path(@preguntum), style: "color: var(--accent); font-size: 0.9em;" %>
    </div>
  <% else %>
    <div style="font-size: 1.15em; line-height: 1.6; color: var(--text-principal);">
      <%= @preguntum.cuerpo_html&.html_safe || @preguntum.cuerpo %>
    </div>
    <div style="margin-top: 15px;">
      <%= link_to "Ver Markdown →", preguntum_path(@preguntum, ver_markdown: true), style: "color: var(--text-secundario); font-size: 0.85em;" %>
    </div>
  <% end %>
</div>

<h2 style="margin-top: 40px; margin-bottom: 20px;">Comentarios en hilo</h2>

<% if usuario_actual %>
  <%= form_with url: preguntum_comentarios_path(@preguntum), local: true, style: "margin-bottom: 30px;" do |f| %>
    <%= f.text_area :cuerpo_markdown, rows: 3, placeholder: "Aporta a la discusion o escribe una solucion... (Markdown soportado)", required: true %>
    <p style="font-size: 0.8em; color: var(--text-secundario); margin: 5px 0;">Puedes usar Markdown: **negrita**, *cursiva*, `codigo`, etc.</p>
    <%= f.submit "Publicar Comentario Principal" %>
  <% end %>
<% else %>
  <p style="background: rgba(242, 214, 114, 0.1); color: #dbab09; padding: 12px; border-radius: 6px; border: 1px solid #dbab09; font-size: 0.95em;">
    <%= link_to "Inicia sesion", entrar_path, style: "font-weight: bold; color: #fff; text-decoration: underline;" %> para participar en la discusion.
  </p>
<% end %>

<div style="margin-top: 20px;">
  <%= render partial: 'comentarios/comentario', collection: @preguntum.comentarios.where(comentario_padre_id: nil).order(created_at: :asc) %>
</div>

<hr style="margin-top: 50px; border: 0; border-top: 1px solid var(--border-color);">

<%# Zona de Gestion de la pregunta %>
<div style="margin-bottom: 40px;">

  <% if usuario_actual && @preguntum.usuario_id == usuario_actual.id %>

    <div style="margin-bottom: 20px; font-size: 0.95em;">
      <%= link_to 'Editar esta Pregunta', edit_preguntum_path(@preguntum), style: "color: var(--accent); font-weight: bold;" %>
      <span style="color: var(--border-color); margin: 0 10px;">|</span>

      <%# MODIFICADO: Ahora es un enlace simple a la pantalla intermedia de confirmacion %>
      <%= link_to 'Borrar esta Pregunta', delete_preguntum_path(@preguntum), style: "color: #da3633; font-weight: bold;" %>
      <span style="color: var(--border-color); margin: 0 10px;">|</span>

      <%= link_to 'Volver a la lista', root_path, style: "color: var(--text-secundario);" %>
    </div>

  <% else %>
    <div style="font-size: 0.95em; margin-top: 20px;">
      <%= link_to 'Volver a la lista', root_path, style: "color: var(--text-secundario);" %>
    </div>
  <% end %>

</div>
